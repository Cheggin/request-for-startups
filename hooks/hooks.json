{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/keyword-detector.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/skill-injector.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/gateguard.mjs"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/gateguard.mjs"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/skill-chain-enforcer.mjs"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/skill-chain-enforcer.mjs"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/project-memory-precompact.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/wiki-pre-compact.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/context-guard-stop.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/persistent-mode.cjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/completion-signal.mjs"
          }
        ]
      }
    ]
  }
}
