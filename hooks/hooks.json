{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/keyword-detector.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/skill-injector.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/project-memory-session.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/wiki-session-start.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "init",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/setup-init.mjs",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "maintenance",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/setup-maintenance.mjs",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/skill-chain-enforcer.mjs"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/skill-chain-enforcer.mjs"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/permission-handler.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/project-memory-posttool.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/subagent-tracker.mjs start",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/subagent-tracker.mjs stop",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/verify-deliverables.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/project-memory-precompact.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/wiki-pre-compact.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/context-guard-stop.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/persistent-mode.cjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/code-simplifier.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/completion-signal.mjs"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/session-end.mjs",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/run.cjs ${CLAUDE_PLUGIN_ROOT}/hooks/wiki-session-end.mjs",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
