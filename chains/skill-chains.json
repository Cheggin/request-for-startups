{
  "$schema": "./skill-chains.schema.json",
  "flows": {
    "website-end-to-end": {
      "description": "Full production-quality website build — discovery through deploy.",
      "trigger_skill": "website-creation",
      "gate_patterns": [
        "app/**",
        "components/**",
        "pages/**",
        "src/**",
        "packages/*/src/**",
        "packages/*/app/**",
        "packages/*/components/**",
        "*.tsx",
        "*.jsx",
        "*.css",
        "*.scss"
      ],
      "phases": [
        {
          "name": "discovery",
          "required": ["shape", "brand-guidelines"]
        },
        {
          "name": "foundation",
          "required": ["website-creation", "impeccable"]
        },
        {
          "name": "assets",
          "required": ["asset-generation", "clarify"]
        },
        {
          "name": "refinement",
          "required": ["layout", "typeset", "colorize", "adapt"]
        },
        {
          "name": "quality",
          "required": [
            "critique",
            "audit",
            "accessibility-checker",
            "visual-qa-pipeline",
            "performance-benchmark"
          ]
        },
        {
          "name": "ship",
          "required": [
            "polish",
            "optimize",
            "seo-setup",
            "test-generator",
            "security-scanner",
            "deploy-pipeline"
          ]
        }
      ]
    },
    "startup-end-to-end": {
      "description": "Full autonomous startup build — founder interview through deploy and growth.",
      "trigger_skill": "startup-init",
      "gate_patterns": [
        "**/app/**",
        "**/components/**",
        "**/pages/**",
        "**/src/**",
        "**/convex/**",
        "**/*.tsx",
        "**/*.jsx",
        "**/*.ts"
      ],
      "phases": [
        {
          "name": "interview",
          "required": ["deep-interview"]
        },
        {
          "name": "research",
          "required": ["competitor-research"]
        },
        {
          "name": "spec",
          "required": ["shape"]
        },
        {
          "name": "design",
          "required": ["brand-guidelines", "website-creation"]
        },
        {
          "name": "infra",
          "required": ["ci-cd-pipeline", "error-tracking", "analytics-integration"]
        },
        {
          "name": "build",
          "required": ["test-generator", "impeccable"]
        },
        {
          "name": "launch",
          "required": [
            "legal-generator",
            "seo-setup",
            "accessibility-checker",
            "security-scanner"
          ]
        },
        {
          "name": "ship",
          "required": ["deploy-pipeline"]
        },
        {
          "name": "growth",
          "required": ["post-deploy-loop"]
        }
      ]
    },
    "deploy-loop": {
      "description": "Safe production deploy — readiness checks, security scan, deploy, post-deploy monitoring.",
      "trigger_skill": "deploy-pipeline",
      "gate_patterns": [
        ".github/workflows/**",
        "vercel.json",
        "railway.json",
        "Dockerfile",
        "docker-compose.yml",
        "docker-compose.*.yml",
        "packages/*/vercel.json",
        "packages/*/railway.json",
        "packages/*/Dockerfile"
      ],
      "phases": [
        {
          "name": "readiness",
          "required": ["verify", "test-generator"]
        },
        {
          "name": "security",
          "required": ["security-scanner"]
        },
        {
          "name": "ship",
          "required": ["deploy-pipeline"]
        },
        {
          "name": "monitor",
          "required": ["uptime-monitor", "error-tracking"]
        }
      ]
    },
    "debug-loop": {
      "description": "Evidence-driven debugging — trace causal hypotheses, diagnose the root cause, verify the fix.",
      "trigger_skill": "debug",
      "gate_patterns": [
        "src/**",
        "app/**",
        "convex/**",
        "packages/*/src/**",
        "packages/*/app/**",
        "*.ts",
        "*.tsx",
        "*.js",
        "*.jsx",
        "**/*.ts",
        "**/*.tsx"
      ],
      "phases": [
        {
          "name": "trace",
          "required": ["trace"]
        },
        {
          "name": "diagnose",
          "required": ["debug"]
        },
        {
          "name": "verify",
          "required": ["verify"]
        }
      ]
    }
  }
}
