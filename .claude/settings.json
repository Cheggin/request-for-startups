{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-inter-agent-signal.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-auto-finish.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-context-handoff.ts"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-inter-agent-signal.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-gateguard.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-gateguard.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-config-protection.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-scope-enforcer.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-metrics-gate.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-skill-chain-enforcer.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-config-protection.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-scope-enforcer.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-metrics-gate.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-skill-chain-enforcer.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-commands.sh"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/validate-commit-msg.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/validate-issue-create.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-deploy-gate.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/run-metrics-gate.ts"
          },
          {
            "type": "command",
            "command": "bun run packages/hooks/src/branch-enforcer.ts"
          }
        ]
      }
    ]
  }
}
