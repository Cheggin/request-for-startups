{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/packages/hooks/src/run-inter-agent-signal.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/packages/hooks/src/run-auto-finish.ts"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/packages/hooks/src/run-inter-agent-signal.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/packages/hooks/src/run-config-protection.ts"
          },
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/packages/hooks/src/run-scope-enforcer.ts"
          },
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/packages/hooks/src/run-metrics-gate.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/packages/hooks/src/run-config-protection.ts"
          },
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/packages/hooks/src/run-scope-enforcer.ts"
          },
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/packages/hooks/src/run-metrics-gate.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/log-commands.sh"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/validate-commit-msg.mjs"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/validate-issue-create.mjs"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/deploy-gate.mjs"
          },
          {
            "type": "command",
            "command": "bun run $CLAUDE_PROJECT_DIR/packages/hooks/src/run-metrics-gate.ts"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/branch-enforcer.mjs"
          }
        ]
      }
    ]
  }
}
