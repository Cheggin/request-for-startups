{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .ui-loop && touch .ui-loop/todos.md .ui-loop/progress.md && cat \"${CLAUDE_PLUGIN_ROOT}/CLAUDE.md\""
          }
        ]
      }
    ]
  }
}
